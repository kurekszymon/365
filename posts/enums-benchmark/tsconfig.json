{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": [
    "src/patterns/const-enum.ts",
    "src/bundle-sizes/const-enum/**",
    "src/tree-shake/const-enum/**"
  ]
}
